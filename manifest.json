{
  "manifest_version": 2,
  "name": "Tab Content Search",
  "version": "1.2.4",
  "description": "搜索所有已打开标签页的页面内容 | Search across all open tabs",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    },
    "default_title": "标签页内容搜索"
  },
  "background": {
    "scripts": ["browser-polyfill.js", "background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser-polyfill.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "tabs",
    "activeTab",
    "<all_urls>"
  ],
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "打开标签页搜索"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-search-extension@Mby159",
      "data_collection_permissions": {
      "required": ["none"]
    }
    }
  }
}
